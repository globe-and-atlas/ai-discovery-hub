# Copy this file to .env and fill in your values
# Never commit .env to git!

# --- Claude API (Required) ---
# Powers the LLM curation pass and lab curriculum expansion
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# --- User Identity (Optional but recommended) ---
# Used to personalize weather lookups and dashboard metadata
USER_NAME=YourName
USER_EMAIL=your.email@example.com
USER_ZIP=12345
USER_CITY=YourCity, ST
USER_TZ=America/Chicago
USER_TZ_LABEL=Central

# --- Weather Coordinates (Optional) ---
# Used for the local weather display on the dashboard (Open-Meteo)
WEATHER_LAT=30.0799
WEATHER_LON=-95.4222

# --- Google / YouTube API (Optional) ---
# YouTube Data API v3 key — required to fetch YouTube channels and search feeds
GOOGLE_API_KEY=your_google_api_key_here
# YOUTUBE_API_KEY=your_youtube_api_key_here (uncomment if using a separate key)

# --- GitHub API (Optional) ---
# personal access token (classic or fine-grained) — raises GitHub search rate limits
GITHUB_TOKEN=your_github_token_here

# --- Stack Exchange API (Optional) ---
# StackApps key — raises GIS Stack Exchange rate limits
# STACKAPPS_KEY=your_stackapps_key_here

# --- LLM Curation Provider Settings ---
HUB_PROVIDER=anthropic
HUB_MODEL=claude-sonnet-4-6
